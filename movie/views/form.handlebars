<h1>{{title}}</h1>

<form action="/movie/save" method="post">
    <input type="hidden" name="id" value="{{movie.id}}">

    <label>Назва:</label><br>
    <input type="text" name="title" value="{{movie.title}}" required><br><br>

    <label>Рік:</label><br>
    <input type="number" name="year" value="{{movie.year}}" required><br><br>

    <label>Рейтинг (1–5):</label><br>
    <input type="number" name="rating" min="1" max="5" value="{{movie.rating}}" required><br><br>

    <button type="submit">Зберегти</button>
</form>

<br>
<a href="/movie">Назад</a>
